# Copy this file to .env and fill in your values
# cp .env.example .env

DATABASE_URL=postgresql://dt_user:dt_pass123@localhost:5432/decentralitrack
SESSION_SECRET=change-this-to-a-random-secret

# Web3 / local chain
# HARDHAT_RPC_URL=http://127.0.0.1:8545
# POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
# DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key
# PRIVKEY_GOVT_OFFICIAL=0x...
# PRIVKEY_AUDITOR=0x...
# PRIVKEY_CONTRACTOR_1=0x...
# PRIVKEY_CONTRACTOR_2=0x...
# ROLE_MANAGER_ADDRESS=0x...
# PROJECT_REGISTRY_ADDRESS=0x...
# MILESTONE_ESCROW_ADDRESS=0x...

# IPFS (optional)
# PINATA_JWT=your_pinata_jwt_token
# PINATA_GATEWAY=https://gateway.pinata.cloud

# Frontend (Vite)
# VITE_ROLE_MANAGER_ADDRESS=0x...
# VITE_PROJECT_REGISTRY_ADDRESS=0x...
# VITE_MILESTONE_ESCROW_ADDRESS=0x...
# VITE_IPFS_GATEWAY=https://gateway.pinata.cloud
# VITE_BLOCK_EXPLORER_URL=https://amoy.polygonscan.com
# VITE_BLOCKCHAIN_STATUS_POLL_MS=5000
# VITE_BLOCKCHAIN_LOG_POLL_MS=8000
